// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String
  password         String?
  role             String   @default("GUEST") // PLATFORM_ADMIN, PRESIDENT, VP, GS, TREASURER, MEDIA, VERIFIER, MEMBER, GUEST
  membershipStatus String   @default("NON_MEMBER") // NON_MEMBER, PENDING, ACTIVE, REJECTED
  avatar           String?
  studentId        String?
  department       String?
  phone            String?
  bio              String?
  transactionId    String?
  paymentProof     String?
  paymentMethod    String?
  paymentDate      String?
  rejectionReason  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  eventRegistrations  EventRegistration[]
  certificates        Certificate[]
  payments            Payment[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  createdEvents       Event[]              @relation("EventCreator")
  verifiedPayments    Payment[]            @relation("PaymentVerifier")
  approvedExpenses    Expense[]            @relation("ExpenseApprover")
  createdExpenses     Expense[]            @relation("ExpenseCreator")
  createdBudgets      Budget[]             @relation("BudgetCreator")
  assessments         AssessmentSubmission[]
  attendance          Attendance[]
  assignedEvents      Event[]              @relation("EventVerifier")
  issuedCertificates  Certificate[]        @relation("CertificateIssuer")
  approvedCertificates Certificate[]       @relation("CertificateApprover")
  revokedCertificates Certificate[]       @relation("CertificateRevoker")
  certificateAuditLogs CertificateAuditLog[]
  galleryImages     GalleryImage[]
  submittedAchievements Achievement[] @relation("AchievementSubmitter")
  approvedAchievements  Achievement[] @relation("AchievementApprover")
}

model Event {
  id                 String   @id @default(cuid())
  title              String
  description        String
  type               String   @default("PUBLIC") // PUBLIC, MEMBER_ONLY, PAID, LIMITED
  category           String   @default("WORKSHOP") // WORKSHOP, SEMINAR, TRAINING, CTF, MEETUP
  startDate          DateTime
  endDate            DateTime
  venue              String
  fee                Float    @default(0)
  maxSeats           Int?
  currentSeats       Int      @default(0)
  poster             String?
  status             String   @default("UPCOMING") // UPCOMING, ONGOING, COMPLETED, CANCELLED
  requiresAssessment Boolean  @default(false)
  passingScore       Float?
  verifierId         String?
  createdBy          String
  certificateLayout  String?  // JSON string: bg image, colors, logos, signatures, placements
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  creator        User                 @relation("EventCreator", fields: [createdBy], references: [id])
  verifier       User?                @relation("EventVerifier", fields: [verifierId], references: [id])
  registrations  EventRegistration[]
  attendance     Attendance[]
  certificates   Certificate[]
  assessments    Assessment[]
  payments       Payment[]
  galleryImages  GalleryImage[]
}

model EventRegistration {
  id            String   @id @default(cuid())
  userId        String
  eventId       String
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED
  preferredName String?
  studentId     String?
  department    String?
  institution   String?
  registeredAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}

model Payment {
  id            String   @id @default(cuid())
  userId        String
  amount        Float
  type          String   @default("MEMBERSHIP") // MEMBERSHIP, EVENT, OTHER
  status        String   @default("PENDING") // PENDING, VERIFIED, REJECTED
  transactionId String
  proofUrl      String?
  eventId       String?
  verifiedBy    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User    @relation(fields: [userId], references: [id])
  event      Event?  @relation(fields: [eventId], references: [id])
  verifier   User?   @relation("PaymentVerifier", fields: [verifiedBy], references: [id])
}

model Budget {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  category    String
  period      String
  createdBy   String
  createdAt   DateTime @default(now())

  creator    User      @relation("BudgetCreator", fields: [createdBy], references: [id])
  expenses   Expense[]
}

model Expense {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  category    String
  description String?
  proofUrl    String?
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  budgetId    String
  createdBy   String
  approvedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  budget   Budget @relation(fields: [budgetId], references: [id])
  creator  User   @relation("ExpenseCreator", fields: [createdBy], references: [id])
  approver User?  @relation("ExpenseApprover", fields: [approvedBy], references: [id])
}

model Attendance {
  id       String   @id @default(cuid())
  userId   String
  eventId  String
  status   String   @default("PRESENT") // PRESENT, ABSENT, LATE
  markedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}

model Certificate {
  id                  String    @id @default(cuid())
  certificateCode     String    @unique
  userId              String
  eventId             String
  type                String    @default("PARTICIPATION") // PARTICIPATION, ACHIEVEMENT, EXCELLENCE
  score               Float?
  status              String    @default("REGISTERED") // REGISTERED, PRESENT, ELIGIBLE, AUTHORIZED, GENERATED, DOWNLOADED, REVOKED
  issuedAt            DateTime  @default(now())

  // Certificate Authority Fields
  issuedBy            String?   // GS who issued the certificate
  approvedBy          String?   // President who approved (for excellence/achievement types)
  revokedBy           String?   // President who revoked
  revokedAt           DateTime? // When revoked
  revocationReason    String?   // Why revoked
  eligibilityVerified Boolean   @default(false) // Whether eligibility was checked before issuance
  eligibilityDetails  String?   // JSON: attendance verified, assessment passed, event completed

  user      User                @relation(fields: [userId], references: [id])
  event     Event               @relation(fields: [eventId], references: [id])
  issuer    User?               @relation("CertificateIssuer", fields: [issuedBy], references: [id])
  approver  User?               @relation("CertificateApprover", fields: [approvedBy], references: [id])
  revoker   User?               @relation("CertificateRevoker", fields: [revokedBy], references: [id])
  auditLogs CertificateAuditLog[]
}

model Assessment {
  id           String   @id @default(cuid())
  eventId      String
  title        String
  questions    String   // JSON string
  maxScore     Float
  passingScore Float
  createdAt    DateTime @default(now())

  event       Event                 @relation(fields: [eventId], references: [id])
  submissions AssessmentSubmission[]
}

model AssessmentSubmission {
  id            String   @id @default(cuid())
  userId        String
  assessmentId  String
  answers       String   // JSON string
  score         Float?
  status        String   @default("SUBMITTED") // SUBMITTED, GRADED
  submittedAt   DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id])
  assessment  Assessment  @relation(fields: [assessmentId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model CertificateAuditLog {
  id            String   @id @default(cuid())
  certificateId String
  action        String   // ISSUED, APPROVED, REVOKED, ELIGIBILITY_CHECKED, VIEWED, SHARED
  performedBy   String
  details       String   // JSON with contextual info
  createdAt     DateTime @default(now())

  certificate Certificate @relation(fields: [certificateId], references: [id])
  performer   User        @relation(fields: [performedBy], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO") // INFO, WARNING, SUCCESS, ERROR
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  type      String   @default("GENERAL") // GENERAL, EVENT, URGENT
  createdBy String
  createdAt DateTime @default(now())
}

model GalleryImage {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  category    String   @default("EVENT") // EVENT, WORKSHOP, CTF, SEMINAR, MEETUP, GENERAL
  eventId     String?
  uploadedBy  String
  createdAt   DateTime @default(now())

  event    Event? @relation(fields: [eventId], references: [id])
  uploader User   @relation(fields: [uploadedBy], references: [id])
}

model Achievement {
  id           String    @id @default(cuid())
  title        String
  description  String
  imageUrl     String?
  category     String    @default("COMPETITION") // COMPETITION, ACADEMIC, COMMUNITY, INDUSTRY, CERTIFICATION
  achievedBy   String?   // Name or group description
  achievedDate DateTime
  status       String    @default("PENDING") // PENDING, APPROVED, REJECTED
  submittedBy  String
  approvedBy   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  submitter User?  @relation("AchievementSubmitter", fields: [submittedBy], references: [id])
  approver  User?  @relation("AchievementApprover", fields: [approvedBy], references: [id])
}

model CommitteeMember {
  id          String   @id @default(cuid())
  name        String
  role        String   // President, Vice President, General Secretary, Treasurer, Media Lead, etc.
  description String
  imageUrl    String?
  department  String?
  email       String?
  socialLinks String?  // JSON: { linkedin, github, twitter }
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemConfig {
  key   String @id
  value String
}
